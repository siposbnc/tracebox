{
  "name": "tracebox",
  "version": "1.1.0",
  "description": "TraceBox — a fast, offline log reader with complex search for huge files",
  "author": "TraceBox",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "start": "node server/main.ts",
    "dev": "node scripts/gen-patchnotes.mjs && node scripts/dev.mjs",
    "build": "node scripts/gen-patchnotes.mjs && vite build",
    "genpatchnotes": "node scripts/gen-patchnotes.mjs",
    "test": "node --test \"server/**/*.test.ts\"",
    "genlog": "node scripts/genlog.mjs",
    "build:electron": "node scripts/build-electron.mjs",
    "app": "npm run build && npm run build:electron && electron .",
    "app:dev": "npm run build:electron && electron .",
    "dist": "npm run build && npm run build:electron && electron-builder --win",
    "dist:dir": "npm run build && npm run build:electron && electron-builder --win --dir",
    "release": "npm run build && npm run build:electron && electron-builder --win --publish always"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@tanstack/react-virtual": "^3.13.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^39.0.0",
    "electron-builder": "^26.0.0",
    "esbuild": "^0.25.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.9.0",
    "vite": "^7.1.0"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
